---
const myName = "Megi Baduni";
const myTitle = "Software Developer";
const myBio = "I am a hardworking and adaptable person with a positive attitude and strong communication skills. I enjoy taking on new challenges and continuously improving my abilities. I am committed to delivering quality work and achieving personal and professional growth.";
const contactEmail = "badunimegi24@gmail.com";
const phoneNumber = "+355 698744696";
const location = "Tirana, Albania";
const githubUrl = "https://github.com/MegiBaduni";

const accentColor = "#00f3ff"; 

const skills = ["Python Developer", "FrontEnd HTML+CSS", "C language", "Algorithms & logic", "Data structure", "Git"];
const education = [
  { school: "University Tirana", degree: "Dega IT", years: "(2025-2028)" },
  { school: "SAMI FRASHERI", degree: "High School (GPA: 9.5)", years: "(2022-2025)" }
];
const experience = [
  { company: "Cisco Academy", role: "C language training", date: "2025" },
  { company: "ICT academy", role: "Programming basics", date: "2024" }
];
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{myName} | Portfolio</title>
		
		<style define:vars={{ accentColor }}>
			:root { --bg: #0a0a0a; --accent: var(--accentColor); --text: #ffffff; --muted: #71717a; --border: #18181b; }
			::-webkit-scrollbar { width: 6px; }
			::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 10px; }
			* { margin: 0; padding: 0; box-sizing: border-box; cursor: none; }
			body { background-color: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; overflow-x: hidden; }
			.glow { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(600px at var(--x, 50%) var(--y, 50%), rgba(0, 243, 255, 0.12), transparent 80%); pointer-events: none; z-index: 999; }
			.cursor-dot { width: 8px; height: 8px; background: var(--accent); position: fixed; border-radius: 50%; pointer-events: none; z-index: 1000; transform: translate(-50%, -50%); transition: transform 0.1s ease; }
			.container { max-width: 1300px; margin: 0 auto; padding: 0 40px; }
			nav { padding: 40px 0; display: flex; justify-content: space-between; align-items: center; text-transform: uppercase; font-size: 10px; letter-spacing: 3px; color: var(--muted); }
			.main-logo { display: flex; align-items: center; font-weight: 800; font-size: 18px; letter-spacing: -1px; color: white; text-transform: none; }
			.main-logo .initials { background-color: var(--accent); color: #000; padding: 6px 10px; border-radius: 4px; margin-right: 12px; font-weight: 900; }
			.status-badge { display: flex; align-items: center; gap: 8px; background: #111; padding: 6px 14px; border-radius: 20px; border: 1px solid #222; font-size: 9px; color: white; }
			.dot { width: 6px; height: 6px; background-color: var(--accent); border-radius: 50%; box-shadow: 0 0 10px var(--accent); animation: pulse 2s infinite; }
			@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
			.hero { padding: 80px 0; }
			h1 { font-size: clamp(3rem, 12vw, 10rem); font-weight: 900; text-transform: uppercase; letter-spacing: -0.05em; margin-bottom: 60px; }
			.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
			.profile-image-container { width: 100%; aspect-ratio: 4/5; background-color: #111; border-radius: 4px; overflow: hidden; border: 1px solid var(--border); }
			.profile-image { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%); transition: 0.5s; }
			.profile-image:hover { filter: grayscale(0%); transform: scale(1.05); }
			.bio { color: var(--muted); font-size: 1.4rem; line-height: 1.5; margin-bottom: 30px; }
			.skill-tag { display: inline-block; padding: 8px 18px; border: 1px solid var(--border); border-radius: 50px; font-size: 10px; text-transform: uppercase; color: var(--muted); margin: 0 8px 8px 0; transition: 0.3s; }
			.skill-tag:hover { border-color: var(--accent); color: var(--accent); }
			.section-label { text-transform: uppercase; font-size: 10px; letter-spacing: 4px; color: var(--accent); margin-top: 120px; margin-bottom: 40px; }
			.row { display: flex; justify-content: space-between; align-items: center; padding: 50px 20px; border-top: 1px solid var(--border); transition: 0.4s; }
			.row:hover { background-color: #0f0f0f; padding-left: 40px; }
			.row h3 { font-size: 2.5rem; text-transform: uppercase; }
			.contact-section { padding: 150px 0 50px 0; border-top: 1px solid var(--border); margin-top: 100px; }
			.big-link { font-size: clamp(2rem, 8vw, 6rem); font-weight: 900; text-transform: uppercase; text-decoration: none; color: white; transition: 0.5s; display: inline-block; }
			.big-link:hover { color: var(--accent); transform: scale(1.02); }
			.availability-box { max-width: 500px; margin: 40px auto; padding: 30px; background: #0f0f0f; border: 1px solid var(--border); border-radius: 12px; text-align: center; }
			.github-btn { display: inline-block; padding: 10px 20px; border: 1px solid var(--accent); color: var(--accent); text-decoration: none; font-size: 11px; text-transform: uppercase; border-radius: 4px; margin-top: 15px; }
			.github-btn:hover { background: var(--accent); color: #000; }
			.footer-details { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin: 60px auto; text-align: center; }
			.copyright { margin-top: 80px; font-size: 9px; color: #222; text-transform: uppercase; text-align: center; }
			@media (max-width: 768px) { .hero-grid, .footer-details { grid-template-columns: 1fr; } .cursor-dot { display: none; } }
		</style>
	</head>
	<body>
		<div class="glow"></div>
		<div class="cursor-dot"></div>
		<div class="container">
			<nav>
				<div class="main-logo"><span class="initials">MB</span> Megi Baduni</div>
				<div class="status-badge"><span class="dot"></span> Available for Projects</div>
				<div style="color: var(--accent)">/ {location}</div>
			</nav>
			<section class="hero">
				<h1>{myTitle}</h1>
				<div class="hero-grid">
					<div class="profile-image-container">
						<img src="/profile.jpg" alt={myName} class="profile-image" />
					</div>
					<div>
						<p class="bio">{myBio}</p>
						<div>{skills.map(skill => <span class="skill-tag">{skill}</span>)}</div>
					</div>
				</div>
			</section>
			<div class="section-label">01 // Experience</div>
			{experience.map(exp => (
				<div class="row">
					<div><h3>{exp.company}</h3><p style="color:var(--muted); font-size:10px;">{exp.role}</p></div>
					<div style="font-family: monospace; color: #333;">{exp.date}</div>
				</div>
			))}
			<div class="section-label">02 // Education</div>
			{education.map(edu => (
				<div class="row">
					<div><h3>{edu.school}</h3><p style="color:var(--muted); font-size:10px;">{edu.degree}</p></div>
					<div style="font-family: monospace; color: #333;">{edu.years}</div>
				</div>
			))}
			<footer class="contact-section">
				<p class="section-label" style="text-align: center; margin-top:0;">03 // Contact</p>
				<div style="text-align: center;"><a href={`mailto:${contactEmail}`} class="big-link">LET'S WORK TOGETHER</a></div>
				<div class="availability-box">
					<h4>AVAILABILITY</h4>
					<p style="color: var(--muted); font-size: 14px; margin-top:10px;">I respond to messages within 24 hours. Open to freelance and collaborations.</p>
					<a href={githubUrl} target="_blank" class="github-btn">View My GitHub</a>
				</div>
				<div class="footer-details">
					<div><span style="color: var(--accent); font-size: 9px;">EMAIL</span><p>{contactEmail}</p></div>
					<div><span style="color: var(--accent); font-size: 9px;">PHONE</span><p>{phoneNumber}</p></div>
					<div><span style="color: var(--accent); font-size: 9px;">LOCATION</span><p>{location}</p></div>
				</div>
				<div class="copyright">© 2026 MB // Built with Astro</div>
			</footer>
		</div>
		<script>
			const glow = document.querySelector('.glow');
			const dot = document.querySelector('.cursor-dot');
			window.addEventListener('mousemove', (e) => {
				glow.style.setProperty('--x', e.clientX + 'px');
				glow.style.setProperty('--y', e.clientY + 'px');
				dot.style.left = e.clientX + 'px';
				dot.style.top = e.clientY + 'px';
			});
		</script>
	</body>
</html>
